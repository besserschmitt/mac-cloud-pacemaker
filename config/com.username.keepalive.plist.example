<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.username.keepalive</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/YOUR_MACOS_USERNAME/mac-cloud-pacemaker/venv/bin/python</string>
        <string>-u</string>
        <string>/Users/YOUR_MACOS_USERNAME/mac-cloud-pacemaker/keep_alive.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/YOUR_MACOS_USERNAME/mac-cloud-pacemaker/keep_alive.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOUR_MACOS_USERNAME/mac-cloud-pacemaker/keep_alive.log</string>
</dict>
</plist>
